{
    "name": "@moduletrace/turboci",
    "version": "1.1.1",
    "description": "A simple and fast cloud deployment CLI tool",
    "main": "dist/index.js",
    "bin": {
        "turboci": "dist/turboci.js"
    },
    "scripts": {
        "dev": "tsc --watch",
        "compile": "bun build ./bin.ts --compile --outfile bin/turboci",
        "build": "bun build ./bin.ts --target=node --outfile=dist/turboci.js --minify",
        "build:all": "bun run compile && bun run build",
        "upload:r2": "bun build:all && bun secrets/write-binaries.ts",
        "schema": "bun scripts/generate-schema.ts"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/inquirer": "^9.0.9",
        "@types/js-yaml": "^4.0.9",
        "@types/lodash": "^4.17.24",
        "@types/node": "^24.12.0",
        "typescript-json-schema": "^0.67.1"
    },
    "peerDependencies": {
        "typescript": "^5.8.3"
    },
    "dependencies": {
        "@aws-sdk/client-ec2": "^3.1017.0",
        "chalk": "^5.6.2",
        "commander": "^14.0.3",
        "googleapis": "^164.1.0",
        "inquirer": "^12.11.1",
        "js-yaml": "^4.1.1",
        "lodash": "^4.17.23",
        "ora": "^8.2.0"
    }
}
